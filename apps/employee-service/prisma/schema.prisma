generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("EMPLOYEE_DATABASE_URL")
}

model Employee {
  id                    String   @id @default(cuid())
  companyId             String
  employeeId            String   @unique
  firstName             String
  middleName            String?
  lastName              String
  fullName              String
  preferredName         String?
  email                 String   @unique
  phone                 String?
  altPhone              String?
  personalEmail         String?
  gender                String?
  dob                   DateTime?
  nationality           String?
  maritalStatus         String?
  disabilityStatus      String?
  disabilityCategory    String?
  bloodGroup            String?
  photo                 String?  @db.Text
  address               String?  @db.Text
  postalAddress         String?
  region                String?
  district              String?
  country               String   @default("Tanzania")
  departmentId          String?
  branchId              String?
  jobTitle              String
  position              String?
  grade                 String?
  businessUnit          String?
  section               String?
  employmentType        String   @default("Permanent")
  recruitmentChannel    String?
  modeOfPayment         String   @default("Monthly")
  status                String   @default("Active")
  managerId             String?
  dateJoined            DateTime
  confirmationDate      DateTime?
  contractType          String?
  contractStartDate     DateTime?
  contractEndDate       DateTime?
  probationStartDate    DateTime?
  probationEndDate      DateTime?
  grossSalary           Float    @default(0)
  salaryGrade           String?
  salaryLevel           String?
  costCentre            String?
  payrollGroup          String?
  socialSecurityType    String?
  socialSecurityNumber  String?
  tinNumber             String?
  nidaNumber            String?
  passportNumber        String?
  bankName              String?
  bankBranch            String?
  bankAccount           String?
  bankAccountName       String?
  mobileMoneyProvider   String?
  mobileMoneyNumber     String?
  leaveBalance          Int      @default(28)
  approvalStage         Int      @default(0)
  approvalStatus        String   @default("Draft")
  technicalSkills       String?  @db.Text
  functionalSkills      String?  @db.Text
  softSkills            String?  @db.Text
  languages             String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  documents             Document[]
  educations            Education[]
  qualifications        Qualification[]
  emergencyContacts     EmergencyContact[]
  family                Family[]

  @@index([companyId])
  @@index([departmentId])
  @@index([branchId])
  @@index([status])
  @@index([email])
  @@map("employees")
}

model Document {
  id          String   @id @default(cuid())
  employeeId  String
  category    String
  fileName    String
  fileUrl     String   @db.Text
  version     Int      @default(1)
  uploadedAt  DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([category])
  @@map("employee_documents")
}

model Education {
  id           String   @id @default(cuid())
  employeeId   String
  institution  String
  qualification String
  award        String
  year         String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_educations")
}

model Qualification {
  id            String   @id @default(cuid())
  employeeId    String
  name          String
  authority     String
  licenseNumber String?
  expiry        DateTime?
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_qualifications")
}

model EmergencyContact {
  id           String   @id @default(cuid())
  employeeId   String
  name         String
  relationship String
  phone        String
  altPhone     String?
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_emergency_contacts")
}

model Family {
  id           String   @id @default(cuid())
  employeeId   String
  name         String
  relationship String
  phone        String?
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_family")
}
