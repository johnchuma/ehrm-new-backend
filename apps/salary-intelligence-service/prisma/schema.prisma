generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("SALARY_INTELLIGENCE_DATABASE_URL")
}

model SalaryBenchmark {
  id           String   @id @default(cuid())
  companyId    String
  jobTitle     String
  department   String
  marketMin    Float
  marketMedian Float
  marketMax    Float
  companyAverage Float @default(0)
  percentile   Float    @default(50)
  recommendation String? @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([companyId, jobTitle, department])
  @@index([companyId])
  @@map("salary_benchmarks")
}

model SalaryStructure {
  id        String   @id @default(cuid())
  companyId String
  grade     String
  level     String
  minSalary Float
  midSalary Float
  maxSalary Float
  description String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, grade, level])
  @@index([companyId])
  @@map("salary_structures")
}
