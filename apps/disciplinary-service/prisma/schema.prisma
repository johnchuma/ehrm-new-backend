generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DISCIPLINARY_DATABASE_URL")
}

model DisciplinaryCase {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String?
  incident     String
  description  String   @db.Text
  date         DateTime
  reportedBy   String?
  severity     String   @default("Moderate")
  status       String   @default("Open")
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  actions      DisciplinaryAction[]

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("disciplinary_cases")
}

model DisciplinaryAction {
  id           String   @id @default(cuid())
  caseId       String
  type         String
  description  String   @db.Text
  effectiveDate DateTime
  issuedBy     String?
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
  case         DisciplinaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("disciplinary_actions")
}
