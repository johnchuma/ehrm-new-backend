generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("CONTRACTS_DATABASE_URL")
}

model Contract {
  id              String   @id @default(cuid())
  companyId       String
  employeeId      String
  employeeName    String?
  type            String
  startDate       DateTime
  endDate         DateTime?
  probationEndDate DateTime?
  basicSalary     Float    @default(0)
  terms           String?  @db.Text
  status          String   @default("Active")
  terminatedAt    DateTime?
  terminationReason String? @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("contracts")
}
