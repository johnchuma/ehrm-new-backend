generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("ONBOARDING_DATABASE_URL")
}

model Onboarding {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String?
  startDate    DateTime
  buddy        String?
  departmentId String?
  position     String?
  currentStage String   @default("Orientation")
  status       String   @default("In Progress")
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  completedAt  DateTime?
  tasks        OnboardingTask[]

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("onboardings")
}

model OnboardingTask {
  id           String   @id @default(cuid())
  onboardingId String
  title        String
  description  String?  @db.Text
  assignee     String?
  dueDate      DateTime?
  status       String   @default("Pending")
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  onboarding   Onboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
  @@map("onboarding_tasks")
}
