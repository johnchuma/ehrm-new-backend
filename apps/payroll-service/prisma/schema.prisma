generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("PAYROLL_DATABASE_URL")
}

model PayrollRun {
  id            String   @id @default(cuid())
  companyId     String
  period        String
  month         String
  year          String
  employees     Int      @default(0)
  gross         Float    @default(0)
  net           Float    @default(0)
  paye          Float    @default(0)
  nssf          Float    @default(0)
  sdl           Float    @default(0)
  wcf           Float    @default(0)
  nhif          Float    @default(0)
  totalCost     Float    @default(0)
  status        String   @default("PENDING_APPROVAL")
  payDate       DateTime
  method        String   @default("Bank + Mobile")
  approverId    String?
  approvedAt    DateTime?
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  rows          PayrollRow[]

  @@index([companyId])
  @@index([year, month])
  @@index([status])
  @@map("payroll_runs")
}

model PayrollRow {
  id                String   @id @default(cuid())
  runId             String
  employeeId        String
  employeeName      String
  designation       String?
  workingDays       Int      @default(0)
  basicSalary       Float    @default(0)
  nightAllowance    Float    @default(0)
  terminationAmount Float    @default(0)
  allowances        Float    @default(0)
  overtime          Float    @default(0)
  grossSalary       Float    @default(0)
  nssf              Float    @default(0)
  paye              Float    @default(0)
  nhif              Float    @default(0)
  heslb             Float    @default(0)
  salaryAdvance     Float    @default(0)
  otherDeduction    Float    @default(0)
  totalDeduction    Float    @default(0)
  netSalary         Float    @default(0)
  employerNssf      Float    @default(0)
  employerNhif      Float    @default(0)
  sdl               Float    @default(0)
  wcf               Float    @default(0)
  totalPayrollCost  Float    @default(0)
  createdAt         DateTime @default(now())
  run               PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([employeeId])
  @@map("payroll_rows")
}

model SalaryAdvance {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String
  amount       Float
  termMonths   Int      @default(6)
  status       String   @default("ACTIVE")
  disbursedAt  DateTime @default(now())
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("salary_advances")
}

model Deduction {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String
  code         String
  amount       Float
  month        String
  year         String
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([employeeId])
  @@map("deductions")
}

model Allowance {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String
  code         String
  amount       Float
  month        String
  year         String
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([employeeId])
  @@map("allowances")
}

model Bonus {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String
  type         String
  amount       Float
  period       String?
  status       String   @default("Pending")
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([employeeId])
  @@map("bonuses")
}

model Settlement {
  id            String   @id @default(cuid())
  companyId     String
  employeeId    String
  employeeName  String
  type          String
  amount        Float
  reason        String?  @db.Text
  effectiveDate DateTime
  status        String   @default("Pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("settlements")
}

model PayrollException {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  employeeName String
  type        String
  description String   @db.Text
  status      String   @default("Open")
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([status])
  @@map("payroll_exceptions")
}
