generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("COMPLIANCE_DATABASE_URL")
}

model ComplianceRequirement {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?  @db.Text
  authority   String
  frequency   String   @default("Monthly")
  dueDate     DateTime
  status      String   @default("Pending")
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@map("compliance_requirements")
}

model StatutoryFiling {
  id        String   @id @default(cuid())
  companyId String
  type      String
  period    String
  amount    Float    @default(0)
  dueDate   DateTime
  authority String
  status    String   @default("Pending")
  reference String?
  filedDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([type])
  @@index([status])
  @@map("statutory_filings")
}
