generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("MOVEMENT_DATABASE_URL")
}

model Transfer {
  id              String   @id @default(cuid())
  companyId       String
  employeeId      String
  employeeName    String?
  fromBranchId    String?
  fromDepartmentId String?
  toBranchId      String?
  toDepartmentId  String?
  effectiveDate   DateTime
  reason          String?  @db.Text
  status          String   @default("Pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("transfers")
}

model Promotion {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String?
  fromTitle    String
  toTitle      String
  fromGrade    String?
  toGrade      String?
  newSalary    Float
  effectiveDate DateTime
  reason       String?  @db.Text
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("promotions")
}
