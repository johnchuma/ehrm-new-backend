generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("COMPANY_DATABASE_URL")
}

model Company {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  email               String
  phone               String
  address             String?  @db.Text
  country             String   @default("Tanzania")
  currency            String   @default("TZS")
  timezone            String   @default("Africa/Dar_es_Salaam")
  logo                String?  @db.Text
  subscriptionPlan    String   @default("FREE")
  industry            String?
  size                String?
  website             String?
  taxId               String?
  registrationNumber  String?
  status              String   @default("ACTIVE")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  branches            Branch[]
  departments         Department[]
  settings            CompanySettings?

  @@index([slug])
  @@index([status])
  @@map("companies")
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  name      String
  code      String
  address   String?  @db.Text
  city      String?
  country   String   @default("Tanzania")
  phone     String?
  email     String?
  managerId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments Department[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("branches")
}

model Department {
  id          String   @id @default(cuid())
  companyId   String
  branchId    String?
  name        String
  code        String
  description String?  @db.Text
  headId      String?
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation(fields: [branchId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@map("departments")
}

model CompanySettings {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  payrollCycle         String   @default("MONTHLY")
  leavePolicy          String?  @db.Text
  workHours            String   @default("8")
  overtimeRate         String   @default("1.5")
  taxSettings          String?  @db.Text
  notificationSettings String?  @db.Text
  themeSettings        String?  @db.Text
  generalSettings      String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}
