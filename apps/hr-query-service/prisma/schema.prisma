generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("HR_QUERY_DATABASE_URL")
}

model FAQ {
  id          String   @id @default(cuid())
  companyId   String
  question    String   @db.Text
  answer      String   @db.Text
  category    String?
  views       Int      @default(0)
  helpfulness Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([category])
  @@map("faqs")
}

model HRTicket {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  userName    String?
  subject     String
  description String   @db.Text
  category    String?
  priority    String   @default("Normal")
  status      String   @default("Open")
  createdAt   DateTime @default(now())
  closedAt    DateTime?
  updatedAt   DateTime @updatedAt
  replies     TicketReply[]

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@map("hr_tickets")
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  userName  String?
  message   String   @db.Text
  createdAt DateTime @default(now())
  ticket    HRTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_replies")
}
