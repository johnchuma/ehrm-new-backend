generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DOCUMENTS_DATABASE_URL")
}

model Document {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String?
  name        String
  type        String   @default("File")
  category    String?
  url         String   @db.Text
  size        Int      @default(0)
  uploadedBy  String?
  description String?  @db.Text
  sharedWith  String?  @db.Text
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([category])
  @@index([type])
  @@map("documents")
}
