generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("ANALYTICS_DATABASE_URL")
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  companyId String
  type      String
  data      String   @db.LongText
  period    String
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([type])
  @@index([period])
  @@map("analytics_snapshots")
}
