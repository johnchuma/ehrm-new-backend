  id              String    @id @default(cuid())
  companyId       String
  assetTag        String?   // Internal human-readable tag e.g. AST-001
  name            String
  category        String    // IT Equipment, Vehicle, Furniture, Machinery, Mobile Device, Office Equipment
  make            String?
  model           String?
  serialNumber    String?
  purchaseDate    String?   // YYYY-MM-DD
  purchasePrice   Decimal?  @db.Decimal(15, 2)
  currentValue    Decimal?  @db.Decimal(15, 2)
  currency        String    @default("TZS")
  location        String?
  branchId        String?
  condition       String    @default("Good") // Good, Fair, Poor, Damaged
  status          String    @default("Available") // Active, Available, Under Maintenance, Disposed
  assignedToId    String?   // Employee currently holding the asset
  warrantyExpiry  String?   // YYYY-MM-DD
  nextMaintenance String?   // YYYY-MM-DD
  notes           String?   @db.Text
  metadata        String?   @db.Text
  deletedAt       DateTime?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedTo    Employee?           @relation("EmployeeAssets", fields: [assignedToId], references: [id])
  branch        Branch?             @relation(fields: [branchId], references: [id])
  allocations   AssetAllocation[]
  maintenance   AssetMaintenance[]

  @@unique([companyId, assetTag])
  @@index([companyId])
  @@index([category])
  @@index([status])
  @@index([condition])
  @@index([assignedToId])
  @@index([deletedAt])
  @@map("assets")
}

model AssetAllocation {
  id                   String    @id @default(cuid())
  companyId            String
  assetId              String
  employeeId           String
  allocatedAt          String    // YYYY-MM-DD
  expectedReturnDate   String?   // YYYY-MM-DD
  returnedAt           String?   // YYYY-MM-DD
  notes                String?   @db.Text
  createdById          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  asset    Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee Employee @relation("EmployeeAssetAllocations", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([assetId])
  @@index([employeeId])
  @@index([returnedAt])
  @@map("asset_allocations")
}

model AssetMaintenance {
  id          String   @id @default(cuid())
  companyId   String
  assetId     String
  type        String   // Routine, Repair, Inspection
  description String   @db.Text
  date        String   // YYYY-MM-DD
  cost        Decimal? @db.Decimal(15, 2)
  currency    String   @default("TZS")
  technician  String?
  status      String   @default("Scheduled") // Scheduled, In Progress, Completed, Cancelled
  nextDue     String?  // YYYY-MM-DD
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([assetId])
  @@index([status])
  @@index([date])
  @@map("asset_maintenance")
}

model AssetProcurement {
  id             String   @id @default(cuid())
  companyId      String
  item           String
  category       String
  quantity       Int      @default(1)
  estimatedCost  Decimal  @db.Decimal(15, 2)
  currency       String   @default("TZS")
  requestedById  String?
  requestedBy    String?  // free-text fallback when no employee id
  department     String?
  justification  String?  @db.Text
  status         String   @default("Pending") // Pending, Approved, Rejected, Ordered, Received
  requestDate    String   // YYYY-MM-DD
  approvedBy     String?
  approvedAt     DateTime?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([requestDate])
  @@map("asset_procurements")
}

// ─── DISCIPLINARY ─────────────────────────────────────────────────────────────

model DisciplinaryCase {
  id             String    @id @default(cuid())
  companyId      String
  caseNumber     String?   // Human-readable e.g. DISC-001
  employeeId     String?   // Optional link to employee record
  employeeName   String
  department     String?
  allegation     String    @db.Text
  category       String    // Misconduct, Gross Misconduct, Poor Performance, Insubordination, Attendance
  severity       String    @default("Minor") // Minor, Serious, Gross
  reportedById   String?
  reportedBy     String?   // free-text
  reportedDate   String    // YYYY-MM-DD
  status         String    @default("Investigation") // Investigation, Notice Issued, Hearing Scheduled, Pending Outcome, Closed, Appealed
  caseOfficerId  String?
  caseOfficer    String?   // free-text
  step           Int       @default(1) // 1..5 step in the pipeline
  closedAt       DateTime?
  notes          String?   @db.Text
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company   Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  hearings  DisciplinaryHearing[]
  outcomes  DisciplinaryOutcome[]
  appeals   DisciplinaryAppeal[]

  @@unique([companyId, caseNumber])
  @@index([companyId])
  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([employeeId])
  @@map("disciplinary_cases")
}

model DisciplinaryHearing {
  id           String   @id @default(cuid())
  companyId    String
  caseId       String
  date         String   // YYYY-MM-DD
  time         String?  // HH:mm
  venue        String?
  panelChair   String?
  panelMembers String?  @db.Text  // JSON array string
  witnesses    String?  @db.Text  // JSON array string
  status       String   @default("Scheduled") // Scheduled, Postponed, Completed, Cancelled
  outcome      String?  @db.Text
  notes        String?  @db.Text
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  case    DisciplinaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([caseId])
  @@index([status])
  @@index([date])
  @@map("disciplinary_hearings")
}

model DisciplinaryOutcome {
  id            String   @id @default(cuid())
  companyId     String
  caseId        String
  decision      String   // Warning, Final Warning, Suspension, Dismissal, No Action
  decisionDate  String   // YYYY-MM-DD
  effectiveDate String?  // YYYY-MM-DD
  appealed      Boolean  @default(false)
  notes         String?  @db.Text
  issuedById    String?
  issuedBy      String?  // free-text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  case    DisciplinaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([caseId])
  @@index([decision])
  @@map("disciplinary_outcomes")
}

model DisciplinaryAppeal {
  id               String    @id @default(cuid())
  companyId        String
  caseId           String
  groundsForAppeal String    @db.Text
  submittedDate    String    // YYYY-MM-DD
  status           String    @default("Under Review") // Under Review, Upheld, Dismissed, Withdrawn
  hearingDate      String?   // YYYY-MM-DD
  panelDecision    String?   @db.Text
  decidedAt        DateTime?
  decidedBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  case    DisciplinaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([caseId])
  @@index([status])
  @@map("disciplinary_appeals")
}
