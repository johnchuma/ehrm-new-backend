generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleScope {
  GLOBAL
  TENANT
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String?   @unique
  phone          String?   @unique
  password       String
  firstName      String
  lastName       String
  fullName       String
  companyId      String?
  employeeId     String?   @unique
  role           String    @default("Employee") // System Admin, Company Admin, Employee
  isActive       Boolean   @default(true)
  emailVerified  Boolean   @default(false)
  phoneVerified  Boolean   @default(false)
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String?
  lastLoginAt    DateTime?
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee       Employee?        @relation(fields: [employeeId], references: [id])
  roles          UserRole[]
  refreshTokens  RefreshToken[]
  passwordResets PasswordReset[]
  notifications  Notification[]
  tasks          Task[]           @relation("TaskAssignee")
  createdTasks   Task[]           @relation("TaskCreator")
  hrQueries      HRQueryMessage[]

  @@index([companyId])
  @@index([email])
  @@index([phone])
  @@map("users")
}

model Role {
  id          String    @id @default(cuid())
  name        String
  slug        String?
  description String?
  scope       RoleScope @default(TENANT)
  companyId   String?
  isSystem    Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@unique([name, companyId])
  @@index([companyId])
  @@index([scope])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @db.VarChar(500)
  jti       String?  @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  ipAddress String?
  userAgent String?  @db.VarChar(500)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model SecurityAlert {
  id         String    @id @default(cuid())
  type       String
  entity     String
  detail     String    @db.Text
  severity   String    @default("Medium")
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  occurredAt DateTime  @default(now())
  createdAt  DateTime  @default(now())

  @@index([resolved])
  @@index([severity])
  @@index([occurredAt])
  @@map("security_alerts")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@map("phone_otps")
}

// ─── COMPANY ─────────────────────────────────────────────────────────────────

model Company {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  email              String
  phone              String    @default("")
  tin                String?   @unique
  address            String?   @db.Text
  city               String?
  country            String    @default("Tanzania")
  currency           String    @default("TZS")
  timezone           String    @default("Africa/Dar_es_Salaam")
  logo               String?   @db.Text
  primaryColor       String?   @default("#EC782B")
  secondaryColor     String?   @default("#1E84B8")
  subscriptionPlan   String    @default("FREE")
  industry           String?
  size               String?
  website            String?
  workspaceType      String    @default("SaaS")
  registrationNumber String?
  status             String    @default("ACTIVE")
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  enabledModules String? @db.Text
  userLimit      Int?

  branches                  Branch[]
  departments               Department[]
  settings                  CompanySettings?
  subscriptions             Subscription[]
  payments                  Payment[]
  employees                 Employee[]
  leaveTypes                LeaveType[]
  shifts                    Shift[]
  holidays                  PublicHoliday[]
  tasks                     Task[]
  businessUnits             BusinessUnit[]
  sections                  Section[]
  jobTitles                 JobTitle[]
  grades                    Grade[]
  positions                 Position[]
  contractTypes             ContractType[]
  contracts                 Contract[]
  offboardings              Offboarding[]
  attendanceBulkSubmissions AttendanceBulkSubmission[]
  salaryGrades              SalaryGrade[]
  workingDays               WorkingDayPattern[]
  locations                 WorkspaceLocation[]
  approvals                 WorkspaceApprovalConfig[]
  announcements             Announcement[]
  billingAlerts             BillingAlert[]
  payrollRuns               PayrollRun[]
  payrollRunItems           PayrollRunItem[]
  payrollAdjustments        PayrollAdjustment[]
  payrollComponents         PayrollComponent[]
  nonPayrollCosts           NonPayrollCost[]
  assets                    Asset[]
  assetProcurements         AssetProcurement[]
  disciplinaryCases         DisciplinaryCase[]
  disciplinaryHearings      DisciplinaryHearing[]
  disciplinaryOutcomes      DisciplinaryOutcome[]
  disciplinaryAppeals       DisciplinaryAppeal[]

  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@map("companies")
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  name      String
  code      String
  address   String?  @db.Text
  city      String?
  country   String   @default("Tanzania")
  phone     String?
  email     String?
  managerId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments Department[]
  employees   Employee[]
  assets      Asset[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("branches")
}

model Department {
  id          String   @id @default(cuid())
  companyId   String
  branchId    String?
  name        String
  code        String
  description String?  @db.Text
  headId      String?
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch?    @relation(fields: [branchId], references: [id])
  employees Employee[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@map("departments")
}

model BusinessUnit {
  id        String     @id @default(cuid())
  companyId String
  name      String
  code      String?
  lead      String?
  notes     String?    @db.Text
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("business_units")
}

model Section {
  id        String     @id @default(cuid())
  companyId String
  name      String
  code      String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("sections")
}

model JobTitle {
  id          String     @id @default(cuid())
  companyId   String
  name        String
  code        String?
  grade       String?
  description String?    @db.Text
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   Employee[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("job_titles")
}

model Grade {
  id        String     @id @default(cuid())
  companyId String
  name      String
  rank      Int        @default(0)
  code      String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("grades")
}

model Position {
  id        String   @id @default(cuid())
  companyId String
  name      String
  code      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("positions")
}

model ContractType {
  id        String     @id @default(cuid())
  companyId String
  name      String
  code      String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
  contracts Contract[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("contract_types")
}

model Contract {
  id                String    @id @default(cuid())
  companyId         String
  employeeId        String
  contractTypeId    String?
  contractNumber    String?
  // Lifecycle status: Draft | Active | Probation | ExpiringSoon | Expired | Renewed | Terminated | Extended
  status            String    @default("Active")
  approvedAt        DateTime?
  approvedBy        String?
  startDate         String
  endDate           String?
  probationEndDate  String?
  signedDate        String?
  noticePeriod      Int?
  autoRenew         Boolean   @default(false)
  salary            Decimal?  @db.Decimal(15, 2)
  currency          String    @default("TZS")
  fileUrl           String?   @db.Text
  fileName          String?
  template          String?
  version           Int       @default(1)
  // Self-link for renewals / extensions
  parentContractId  String?
  // Termination
  terminationReason String?
  terminationNotes  String?   @db.Text
  terminatedAt      DateTime?
  terminatedBy      String?
  metadata          String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee       Employee      @relation("EmployeeContracts", fields: [employeeId], references: [id], onDelete: Cascade)
  contractType   ContractType? @relation(fields: [contractTypeId], references: [id])
  parentContract Contract?     @relation("ContractVersions", fields: [parentContractId], references: [id])
  childContracts Contract[]    @relation("ContractVersions")
  offboardings   Offboarding[]

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([endDate])
  @@map("contracts")
}

model SalaryGrade {
  id        String   @id @default(cuid())
  companyId String
  name      String
  code      String?
  rank      Int      @default(0)
  minSalary Decimal? @db.Decimal(15, 2)
  maxSalary Decimal? @db.Decimal(15, 2)
  currency  String   @default("TZS")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("salary_grades")
}

model WorkingDayPattern {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  pattern     String?
  hours       String?
  weekend     String?
  weekendDays String?  @db.Text
  dayConfigs  String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("working_day_patterns")
}

model WorkspaceLocation {
  id           String   @id @default(cuid())
  companyId    String
  name         String
  code         String?
  city         String?
  country      String?
  type         String?
  address      String?  @db.Text
  radiusMeters Int?
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  isActive     Boolean  @default(true)
  metadata     String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("workspace_locations")
}

model WorkspaceApprovalConfig {
  id                    String   @id @default(cuid())
  companyId             String
  moduleKey             String
  process               String?
  levels                Int      @default(1)
  approvalMode          String   @default("global")
  initiatorDepartments  String?  @db.Text
  initiators            String?  @db.Text
  initiatorRule         String?  @default("any")
  reviewerDepartments   String?  @db.Text
  reviewers             String?  @db.Text
  reviewerRule          String?  @default("any")
  approverDepartments   String?  @db.Text
  approvers             String?  @db.Text
  approverRule          String?  @default("any")
  departmentAssignments String?  @db.Text
  escalation            String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, moduleKey])
  @@index([companyId])
  @@map("workspace_approval_configs")
}

model CompanySettings {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  payrollCycle         String   @default("MONTHLY")
  leavePolicy          String?  @db.Text
  workHours            String   @default("8")
  overtimeRate         String   @default("1.5")
  taxSettings          String?  @db.Text
  notificationSettings String?  @db.Text
  themeSettings        String?  @db.Text
  generalSettings      String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

// ─── PLANS & SUBSCRIPTIONS ───────────────────────────────────────────────────

model Plan {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  description   String?  @db.Text
  monthlyPrice  Decimal  @default(0) @db.Decimal(10, 2)
  annualPrice   Decimal  @default(0) @db.Decimal(10, 2)
  maxEmployees  Int      @default(-1)
  features      String?  @db.Text
  isActive      Boolean  @default(true)
  isPublic      Boolean  @default(true)
  isHighlighted Boolean  @default(false)
  supportTier   String   @default("Email")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
  payments      Payment[]

  @@index([slug])
  @@map("plans")
}

model Subscription {
  id                 String    @id @default(cuid())
  companyId          String
  planId             String
  status             String    @default("ACTIVE")
  billingInterval    String    @default("MONTHLY")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  cancelReason       String?
  trialEndsAt        DateTime?
  gatewayRef         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([companyId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id              String    @id @default(cuid())
  companyId       String
  planId          String
  subscriptionId  String?
  amount          Decimal   @db.Decimal(15, 2)
  currency        String    @default("TZS")
  billingInterval String    @default("MONTHLY")
  status          String    @default("PENDING")
  gateway         String    @default("snipepay")
  gatewayRef      String?   @unique
  gatewayResponse String?   @db.Text
  callbackUrl     String?   @db.Text
  paidAt          DateTime?
  failedAt        DateTime?
  failureReason   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan         Plan          @relation(fields: [planId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([gatewayRef])
  @@map("payments")
}

model ImpersonationAudit {
  id              String    @id @default(cuid())
  superAdminId    String
  targetCompanyId String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  expiresAt       DateTime
  ipAddress       String?
  createdAt       DateTime  @default(now())

  @@index([superAdminId])
  @@index([targetCompanyId])
  @@map("impersonation_audits")
}

model BillingAlert {
  id         String    @id @default(cuid())
  type       String
  companyId  String
  message    String    @db.Text
  severity   String    @default("Medium")
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  occurredAt DateTime  @default(now())
  createdAt  DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([resolved])
  @@index([severity])
  @@map("billing_alerts")
}

// ─── EMPLOYEE ────────────────────────────────────────────────────────────────

model Employee {
  id                String    @id @default(cuid())
  companyId         String
  branchId          String?
  departmentId      String?
  managerId         String?
  employeeNumber    String?
  jobTitleId        String?
  gradeId           String?
  sectionId         String?
  businessUnitId    String?
  contractTypeId    String?
  employmentType    String    @default("FULL_TIME")
  employmentMode    String    @default("ONSITE")
  startDate         DateTime?
  endDate           DateTime?
  status            String    @default("ACTIVE")
  basicSalary       Decimal   @default(0) @db.Decimal(15, 2)
  currency          String    @default("TZS")
  // Personal info
  firstName         String?
  lastName          String?
  fullName          String?
  email             String?
  phone             String?
  gender            String?
  dateOfBirth       DateTime?
  nationalId        String?
  tin               String?
  nssfNumber        String?
  passportNumber    String?
  nationality       String?
  maritalStatus     String?
  address           String?   @db.Text
  city              String?
  profilePhoto      String?
  // Banking
  bankName          String?
  bankAccount       String?
  bankBranch        String?
  mobileMoney       String?
  mobileMoneyName   String?
  // Emergency contact
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  // Compensation
  gross             Float?
  // Onboarding workflow (company admin)
  stage             String    @default("Draft")
  approvalStage     Int       @default(0)
  role              String?
  joiningDate       String?
  contractStartDate String?
  contractEndDate   String?
  probationEndDate  String?
  modeOfPayment     String?
  // Rich JSON data blobs
  checklist         String?   @db.Text
  complianceStatus  String?   @db.Text
  documents         String?   @db.Text
  education         String?   @db.Text
  qualifications    String?   @db.Text
  skills            String?   @db.Text
  languages         String?   @db.Text
  emergencyContacts String?   @db.Text
  family            String?   @db.Text
  metadata          String?   @db.Text
  // System
  userId            String?
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch               Branch?              @relation(fields: [branchId], references: [id])
  department           Department?          @relation(fields: [departmentId], references: [id])
  jobTitle             JobTitle?            @relation(fields: [jobTitleId], references: [id])
  grade                Grade?               @relation(fields: [gradeId], references: [id])
  section              Section?             @relation(fields: [sectionId], references: [id])
  businessUnit         BusinessUnit?        @relation(fields: [businessUnitId], references: [id])
  contractType         ContractType?        @relation(fields: [contractTypeId], references: [id])
  user                 User?
  leaveBalances        LeaveBalance[]
  leaveRequests        LeaveRequest[]
  attendance           Attendance[]
  payslips             Payslip[]
  salaryAdvances       SalaryAdvance[]
  hrQueries            HRQuery[]
  shiftAssignments     ShiftAssignment[]
  employeeDocuments    EmployeeDocument[]   @relation("EmployeeDocuments")
  trainingEnrollments  TrainingEnrollment[]
  benefitEnrollments   BenefitEnrollment[]
  expenseClaims        ExpenseClaim[]
  performanceReviews   PerformanceReview[]
  performanceGoals     PerformanceGoal[]
  swapRequestsSent     ShiftSwapRequest[]   @relation("SwapRequester")
  swapRequestsReceived ShiftSwapRequest[]   @relation("SwapTarget")
  contracts            Contract[]           @relation("EmployeeContracts")
  offboardings         Offboarding[]
  payrollRunItems      PayrollRunItem[]
  payrollAdjustments   PayrollAdjustment[]
  payrollComponents    PayrollComponent[]
  assetsAssigned       Asset[]              @relation("EmployeeAssets")
  assetAllocations     AssetAllocation[]    @relation("EmployeeAssetAllocations")

  @@unique([companyId, employeeNumber])
  @@index([companyId])
  @@index([departmentId])
  @@index([managerId])
  @@map("employees")
}

model Offboarding {
  id                         String    @id @default(cuid())
  companyId                  String
  employeeId                 String
  contractId                 String?
  reason                     String
  type                       String
  exitDate                   String
  terminationGround          String?
  noticePeriodDays           Int?
  noticeDate                 String?
  retirementDate             String?
  retirementBenefits         String?
  redundancyReason           String?
  redundancyConsultationDate String?
  settlementJson             String?   @db.Text
  interviewJson              String?   @db.Text
  knowledgeTransferJson      String?   @db.Text
  handoverJson               String?   @db.Text
  clearancesJson             String?   @db.Text
  assetsJson                 String?   @db.Text
  systemAccessRevoked        Boolean   @default(false)
  idCardCollected            Boolean   @default(false)
  approvalStage              Int       @default(0)
  status                     String    @default("Pending Approval")
  approvedAt                 DateTime?
  approvedBy                 String?
  completedAt                DateTime?
  completedBy                String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id])

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([exitDate])
  @@map("offboardings")
}

model EmployeeMovement {
  id            String    @id @default(cuid())
  companyId     String
  employeeId    String
  employeeName  String?
  movementType  String // Promotion, Transfer, Salary Change, Acting Appointment, Reassignment
  fromValue     String? // previous grade, branch, department, salary, etc.
  toValue       String? // proposed grade, branch, department, salary, etc.
  reason        String?   @db.Text
  effectiveDate String?
  status        String    @default("Pending") // Pending, Approved, Rejected
  approvedBy    String?
  approvedAt    DateTime?
  metadata      String?   @db.Text
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId])
  @@index([employeeId])
