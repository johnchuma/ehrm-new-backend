generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum RoleScope {
  GLOBAL
  TENANT
}

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  phone           String?   @unique
  password        String
  firstName       String
  lastName        String
  fullName        String
  companyId       String?
  employeeId      String?
  isActive        Boolean   @default(true)
  emailVerified   Boolean   @default(false)
  phoneVerified   Boolean   @default(false)
  mfaEnabled      Boolean   @default(false)
  mfaSecret       String?
  lastLoginAt     DateTime?
  failedAttempts  Int       @default(0)
  lockedUntil     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  roles           UserRole[]
  refreshTokens   RefreshToken[]
  passwordResets  PasswordReset[]

  @@index([companyId])
  @@index([email])
  @@index([phone])
  @@map("users")
}

model Role {
  id          String     @id @default(cuid())
  name        String
  slug        String?
  description String?
  scope       RoleScope  @default(TENANT)
  companyId   String?
  isSystem    Boolean    @default(false)
  isActive    Boolean    @default(true)
  createdBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       UserRole[]
  permissions RolePermission[]

  @@unique([name, companyId])
  @@index([companyId])
  @@index([scope])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())
  roles       RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  jti       String?  @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_resets")
}

model AuditLog {
  id              String   @id @default(cuid())
  actorId         String?
  originalActorId String?
  companyId       String?
  action          String
  resource        String
  resourceId      String?
  before          String?  @db.Text
  after           String?  @db.Text
  details         String?  @db.Text
  ipAddress       String?
  userAgent       String?  @db.Text
  requestId       String?
  createdAt       DateTime @default(now())

  @@index([actorId])
  @@index([companyId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model ImpersonationAudit {
  id              String    @id @default(cuid())
  superAdminId    String
  targetCompanyId String
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  expiresAt       DateTime
  ipAddress       String?
  createdAt       DateTime  @default(now())

  @@index([superAdminId])
  @@index([targetCompanyId])
  @@map("impersonation_audits")
}

model Company {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  email               String
  phone               String    @default("")
  tin                 String?   @unique
  address             String?   @db.Text
  city                String?
  country             String    @default("Tanzania")
  currency            String    @default("TZS")
  timezone            String    @default("Africa/Dar_es_Salaam")
  logo                String?   @db.Text
  primaryColor        String?   @default("#EC782B")
  secondaryColor      String?   @default("#1E84B8")
  subscriptionPlan    String    @default("FREE")
  industry            String?
  size                String?
  website             String?
  workspaceType       String    @default("SaaS")
  registrationNumber  String?
  status              String    @default("ACTIVE")
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  branches            Branch[]
  departments         Department[]
  settings            CompanySettings?
  subscriptions       Subscription[]

  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@map("companies")
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  name      String
  code      String
  address   String?  @db.Text
  city      String?
  country   String   @default("Tanzania")
  phone     String?
  email     String?
  managerId String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments Department[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("branches")
}

model Department {
  id          String   @id @default(cuid())
  companyId   String
  branchId    String?
  name        String
  code        String
  description String?  @db.Text
  headId      String?
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation(fields: [branchId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@map("departments")
}

model DemoRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  size      String?
  message   String?
  createdAt DateTime @default(now())

  @@map("demo_requests")
}

model CompanySettings {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  payrollCycle         String   @default("MONTHLY")
  leavePolicy          String?  @db.Text
  workHours            String   @default("8")
  overtimeRate         String   @default("1.5")
  taxSettings          String?  @db.Text
  notificationSettings String?  @db.Text
  themeSettings        String?  @db.Text
  generalSettings      String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

model Plan {
  id           String    @id @default(cuid())
  name         String    @unique
  slug         String    @unique
  description  String?   @db.Text
  monthlyPrice Decimal   @db.Decimal(10, 2) @default(0)
  annualPrice  Decimal   @db.Decimal(10, 2) @default(0)
  maxEmployees Int       @default(-1)
  features     String?   @db.Text
  isActive     Boolean   @default(true)
  isPublic     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  subscriptions Subscription[]

  @@index([slug])
  @@map("plans")
}

model Subscription {
  id                   String    @id @default(cuid())
  companyId            String
  planId               String
  status               String    @default("ACTIVE")
  billingInterval      String    @default("MONTHLY")
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelledAt          DateTime?
  cancelReason         String?
  trialEndsAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan                 Plan      @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}
