generator client {
  output   = "./node_modules/.prisma/client"
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ IAM ============

model User {
  id             String          @id @default(cuid())
  email          String?         @unique
  phone          String?         @unique
  password       String
  firstName      String
  lastName       String
  fullName       String
  companyId      String
  employeeId     String?
  isActive       Boolean         @default(true)
  emailVerified  Boolean         @default(false)
  phoneVerified  Boolean         @default(false)
  mfaEnabled     Boolean         @default(false)
  mfaSecret      String?
  lastLoginAt    DateTime?
  failedAttempts Int             @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  roles          UserRole[]
  refreshTokens  RefreshToken[]
  passwordResets PasswordReset[]

  @@index([companyId])
  @@index([email])
  @@index([phone])
  @@map("users")
}

model Role {
  id          String           @id @default(cuid())
  name        String
  description String?
  companyId   String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]

  @@unique([name, companyId])
  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_resets")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  companyId String?
  action    String
  resource  String
  details   String?  @db.Text
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([companyId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============ COMPANY ============

model Company {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  email              String
  phone              String
  address            String?          @db.Text
  country            String           @default("Tanzania")
  currency           String           @default("TZS")
  timezone           String           @default("Africa/Dar_es_Salaam")
  logo               String?          @db.Text
  subscriptionPlan   String           @default("FREE")
  industry           String?
  size               String?
  website            String?
  taxId              String?
  registrationNumber String?
  status             String           @default("ACTIVE")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  branches           Branch[]
  departments        Department[]
  settings           CompanySettings?

  @@index([slug])
  @@index([status])
  @@map("companies")
}

model Branch {
  id          String       @id @default(cuid())
  companyId   String
  name        String
  code        String
  address     String?      @db.Text
  city        String?
  country     String       @default("Tanzania")
  phone       String?
  email       String?
  managerId   String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departments Department[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("branches")
}

model Department {
  id          String   @id @default(cuid())
  companyId   String
  branchId    String?
  name        String
  code        String
  description String?  @db.Text
  headId      String?
  parentId    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch      Branch?  @relation(fields: [branchId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
  @@map("departments")
}

model CompanySettings {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  payrollCycle         String   @default("MONTHLY")
  leavePolicy          String?  @db.Text
  workHours            String   @default("8")
  overtimeRate         String   @default("1.5")
  taxSettings          String?  @db.Text
  notificationSettings String?  @db.Text
  themeSettings        String?  @db.Text
  generalSettings      String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

// ============ EMPLOYEE ============

model Employee {
  id                   String             @id @default(cuid())
  companyId            String
  employeeId           String             @unique
  firstName            String
  middleName           String?
  lastName             String
  fullName             String
  preferredName        String?
  email                String             @unique
  phone                String?
  altPhone             String?
  personalEmail        String?
  gender               String?
  dob                  DateTime?
  nationality          String?
  maritalStatus        String?
  disabilityStatus     String?
  disabilityCategory   String?
  bloodGroup           String?
  photo                String?            @db.Text
  address              String?            @db.Text
  postalAddress        String?
  region               String?
  district             String?
  country              String             @default("Tanzania")
  departmentId         String?
  branchId             String?
  jobTitle             String
  position             String?
  grade                String?
  businessUnit         String?
  section              String?
  employmentType       String             @default("Permanent")
  recruitmentChannel   String?
  modeOfPayment        String             @default("Monthly")
  status               String             @default("Active")
  managerId            String?
  dateJoined           DateTime
  confirmationDate     DateTime?
  contractType         String?
  contractStartDate    DateTime?
  contractEndDate      DateTime?
  probationStartDate   DateTime?
  probationEndDate     DateTime?
  grossSalary          Float              @default(0)
  salaryGrade          String?
  salaryLevel          String?
  costCentre           String?
  payrollGroup         String?
  socialSecurityType   String?
  socialSecurityNumber String?
  tinNumber            String?
  nidaNumber           String?
  passportNumber       String?
  bankName             String?
  bankBranch           String?
  bankAccount          String?
  bankAccountName      String?
  mobileMoneyProvider  String?
  mobileMoneyNumber    String?
  leaveBalance         Int                @default(28)
  approvalStage        Int                @default(0)
  approvalStatus       String             @default("Draft")
  technicalSkills      String?            @db.Text
  functionalSkills     String?            @db.Text
  softSkills           String?            @db.Text
  languages            String?            @db.Text
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  documents            EmployeeDocument[]
  educations           Education[]
  qualifications       Qualification[]
  emergencyContacts    EmergencyContact[]
  family               Family[]

  @@index([companyId])
  @@index([departmentId])
  @@index([branchId])
  @@index([status])
  @@index([email])
  @@map("employees")
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  category   String
  fileName   String
  fileUrl    String   @db.Text
  version    Int      @default(1)
  uploadedAt DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([category])
  @@map("employee_documents")
}

model Education {
  id            String   @id @default(cuid())
  employeeId    String
  institution   String
  qualification String
  award         String
  year          String
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_educations")
}

model Qualification {
  id            String    @id @default(cuid())
  employeeId    String
  name          String
  authority     String
  licenseNumber String?
  expiry        DateTime?
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_qualifications")
}

model EmergencyContact {
  id           String   @id @default(cuid())
  employeeId   String
  name         String
  relationship String
  phone        String
  altPhone     String?
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_emergency_contacts")
}

model Family {
  id           String   @id @default(cuid())
  employeeId   String
  name         String
  relationship String
  phone        String?
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_family")
}

// ============ ATTENDANCE ============

model AttendanceRecord {
  id         String    @id @default(cuid())
  employeeId String
  companyId  String
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  hours      Float     @default(0)
  method     String    @default("Web")
  status     String    @default("Present")
  lat        Float?
  lng        Float?
  deviceId   String?
  notes      String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([employeeId, date])
  @@index([companyId])
  @@index([date])
  @@index([status])
  @@map("attendance_records")
}

model AttendanceException {
  id         String    @id @default(cuid())
  employeeId String
  companyId  String
  type       String
  date       DateTime
  details    String?   @db.Text
  severity   String    @default("Moderate")
  flagged    Boolean   @default(false)
  status     String    @default("Open")
  notes      String?   @db.Text
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("attendance_exceptions")
}

model Shift {
  id           String            @id @default(cuid())
  companyId    String
  name         String
  startTime    String
  endTime      String
  type         String            @default("Regular")
  graceMinutes Int               @default(15)
  color        String            @default("blue")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  assignments  ShiftAssignment[]

  @@index([companyId])
  @@map("shifts")
}

model ShiftAssignment {
  id            String   @id @default(cuid())
  employeeId    String
  shiftId       String
  status        String   @default("Active")
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())
  shift         Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([shiftId])
  @@map("shift_assignments")
}

model ShiftSwap {
  id          String   @id @default(cuid())
  requesterId String
  requesteeId String
  companyId   String
  date        DateTime
  fromShift   String
  toShift     String
  reason      String?  @db.Text
  status      String   @default("Pending")
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([status])
  @@map("shift_swaps")
}

model Overtime {
  id          String    @id @default(cuid())
  employeeId  String
  companyId   String
  date        DateTime
  hours       Float
  rate        Float     @default(1.5)
  reason      String?   @db.Text
  status      String    @default("Pending")
  submittedAt DateTime  @default(now())
  approvedAt  DateTime?

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("overtime_requests")
}

model Geofence {
  id        String   @id @default(cuid())
  companyId String
  name      String
  type      String   @default("Office")
  lat       Float
  lng       Float
  radius    Int      @default(100)
  branchIds String?  @db.Text
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("geofences")
}

model AttendanceApproval {
  id          String   @id @default(cuid())
  employeeId  String
  companyId   String
  type        String
  date        DateTime
  detail      String?  @db.Text
  reviewer    String?
  status      String   @default("Pending")
  notes       String?  @db.Text
  submittedAt DateTime @default(now())

  @@index([companyId])
  @@index([status])
  @@map("attendance_approvals")
}

// ============ LEAVE ============

model LeaveRequest {
  id          String   @id @default(cuid())
  companyId   String
  employeeId  String
  leaveTypeId String
  from        DateTime
  to          DateTime
  days        Float
  reason      String?  @db.Text
  status      String   @default("Pending")
  approverId  String?
  comments    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([from, to])
  @@map("leave_requests")
}

model LeaveType {
  id              String         @id @default(cuid())
  companyId       String
  name            String
  entitlementDays Float
  color           String         @default("orange")
  accrual         String         @default("Monthly")
  carryForward    String         @default("Allowed")
  eligibility     String?
  maxCarry        Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  balances        LeaveBalance[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("leave_types")
}

model LeaveBalance {
  id          String    @id @default(cuid())
  employeeId  String
  leaveTypeId String
  opening     Float     @default(0)
  accrued     Float     @default(0)
  used        Float     @default(0)
  available   Float     @default(0)
  year        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
  @@map("leave_balances")
}

model LeaveEncashment {
  id          String    @id @default(cuid())
  companyId   String
  employeeId  String
  leaveTypeId String
  days        Float
  amount      Float
  status      String    @default("Pending")
  submittedAt DateTime  @default(now())
  processedAt DateTime?

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("leave_encashments")
}

model BlackoutPeriod {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  from        DateTime
  to          DateTime
  scope       String
  description String?  @db.Text
  status      String   @default("Active")
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@map("leave_blackout_periods")
}

model LeaveAccrualRule {
  id        String   @id @default(cuid())
  companyId String
  type      String
  desc      String   @db.Text
  appliesTo String
  createdAt DateTime @default(now())

  @@index([companyId])
  @@map("leave_accrual_rules")
}

// ============ PAYROLL ============

model PayrollRun {
  id          String       @id @default(cuid())
  companyId   String
  period      String
  month       String
  year        String
  employees   Int          @default(0)
  gross       Float        @default(0)
  net         Float        @default(0)
  paye        Float        @default(0)
  nssf        Float        @default(0)
  sdl         Float        @default(0)
  wcf         Float        @default(0)
  nhif        Float        @default(0)
  totalCost   Float        @default(0)
  status      String       @default("PENDING_APPROVAL")
  payDate     DateTime
  method      String       @default("Bank + Mobile")
  approverId  String?
  approvedAt  DateTime?
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rows        PayrollRow[]

  @@index([companyId])
  @@index([year, month])
  @@index([status])
  @@map("payroll_runs")
}

model PayrollRow {
  id                String     @id @default(cuid())
  runId             String
  employeeId        String
  employeeName      String
  designation       String?
  workingDays       Int        @default(0)
  basicSalary       Float      @default(0)
  nightAllowance    Float      @default(0)
  terminationAmount Float      @default(0)
  allowances        Float      @default(0)
  overtime          Float      @default(0)
  grossSalary       Float      @default(0)
  nssf              Float      @default(0)
  paye              Float      @default(0)
  nhif              Float      @default(0)
  heslb             Float      @default(0)
  salaryAdvance     Float      @default(0)
  otherDeduction    Float      @default(0)
  totalDeduction    Float      @default(0)
  netSalary         Float      @default(0)
  employerNssf      Float      @default(0)
  employerNhif      Float      @default(0)
  sdl               Float      @default(0)
  wcf               Float      @default(0)
  totalPayrollCost  Float      @default(0)
  createdAt         DateTime   @default(now())
  run               PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([employeeId])
  @@map("payroll_rows")
}

model SalaryAdvance {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String
  amount       Float
  termMonths   Int      @default(6)
  status       String   @default("ACTIVE")
  disbursedAt  DateTime @default(now())
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("salary_advances")
}

model Deduction {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String
  code         String
  amount       Float
  month        String
  year         String
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([employeeId])
  @@map("deductions")
}

model Allowance {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String
  code         String
  amount       Float
  month        String
  year         String
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([employeeId])
  @@map("allowances")
}

model Bonus {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String
  type         String
  amount       Float
  period       String?
  status       String   @default("Pending")
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([employeeId])
  @@map("bonuses")
}

model Settlement {
  id            String   @id @default(cuid())
  companyId     String
  employeeId    String
  employeeName  String
  type          String
  amount        Float
  reason        String?  @db.Text
  effectiveDate DateTime
  status        String   @default("Pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("settlements")
}

model PayrollException {
  id           String   @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String
  type         String
  description  String   @db.Text
  status       String   @default("Open")
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([status])
  @@map("payroll_exceptions")
}

// ============ PERFORMANCE ============

model Review {
  id           String    @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String
  reviewerId   String
  reviewerName String?
  period       String
  type         String    @default("Annual")
  rating       Float     @default(0)
  strengths    String?   @db.Text
  improvements String?   @db.Text
  comments     String?   @db.Text
  status       String    @default("Draft")
  submittedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("performance_reviews")
}

model Goal {
  id           String    @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String
  title        String
  description  String?   @db.Text
  category     String?
  targetDate   DateTime?
  weight       Float     @default(1.0)
  progress     Float     @default(0)
  status       String    @default("In Progress")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("performance_goals")
}

model Kpi {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?  @db.Text
  unit        String?
  target      Float    @default(0)
  actual      Float    @default(0)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([category])
  @@map("performance_kpis")
}

// ============ TRAINING ============

model TrainingProgram {
  id              String               @id @default(cuid())
  companyId       String
  title           String
  description     String?              @db.Text
  category        String?
  trainer         String?
  startDate       DateTime
  endDate         DateTime
  location        String?
  maxParticipants Int                  @default(20)
  enrolled        Int                  @default(0)
  status          String               @default("Upcoming")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  enrollments     TrainingEnrollment[]

  @@index([companyId])
  @@index([status])
  @@index([category])
  @@map("training_programs")
}

model TrainingEnrollment {
  id           String          @id @default(cuid())
  programId    String
  programTitle String?
  employeeId   String
  employeeName String?
  status       String          @default("Enrolled")
  score        Float?
  feedback     String?         @db.Text
  enrolledAt   DateTime        @default(now())
  completedAt  DateTime?
  program      TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, employeeId])
  @@index([programId])
  @@index([employeeId])
  @@map("training_enrollments")
}

model Certification {
  id                String    @id @default(cuid())
  employeeId        String
  employeeName      String?
  programId         String
  programTitle      String?
  certificateNumber String    @unique
  issuedDate        DateTime
  expiryDate        DateTime?
  createdAt         DateTime  @default(now())

  @@index([employeeId])
  @@index([programId])
  @@map("certifications")
}

// ============ ONBOARDING ============

model Onboarding {
  id           String           @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String?
  startDate    DateTime
  buddy        String?
  departmentId String?
  position     String?
  currentStage String           @default("Orientation")
  status       String           @default("In Progress")
  notes        String?          @db.Text
  createdAt    DateTime         @default(now())
  completedAt  DateTime?
  tasks        OnboardingTask[]

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("onboardings")
}

model OnboardingTask {
  id           String     @id @default(cuid())
  onboardingId String
  title        String
  description  String?    @db.Text
  assignee     String?
  dueDate      DateTime?
  status       String     @default("Pending")
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  onboarding   Onboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
  @@map("onboarding_tasks")
}

// ============ OFFBOARDING ============

model Offboarding {
  id             String      @id @default(cuid())
  companyId      String
  employeeId     String
  employeeName   String?
  reason         String
  type           String      @default("Resignation")
  lastWorkingDay DateTime
  noticeDate     DateTime
  status         String      @default("In Progress")
  notes          String?     @db.Text
  createdAt      DateTime    @default(now())
  completedAt    DateTime?
  clearances     Clearance[]

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("offboardings")
}

model Clearance {
  id            String      @id @default(cuid())
  offboardingId String
  department    String
  items         String?     @db.Text
  status        String      @default("Pending")
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  offboarding   Offboarding @relation(fields: [offboardingId], references: [id], onDelete: Cascade)

  @@index([offboardingId])
  @@map("clearances")
}

// ============ MOVEMENT ============

model Transfer {
  id               String   @id @default(cuid())
  companyId        String
  employeeId       String
  employeeName     String?
  fromBranchId     String?
  fromDepartmentId String?
  toBranchId       String?
  toDepartmentId   String?
  effectiveDate    DateTime
  reason           String?  @db.Text
  status           String   @default("Pending")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("transfers")
}

model Promotion {
  id            String   @id @default(cuid())
  companyId     String
  employeeId    String
  employeeName  String?
  fromTitle     String
  toTitle       String
  fromGrade     String?
  toGrade       String?
  newSalary     Float
  effectiveDate DateTime
  reason        String?  @db.Text
  status        String   @default("Pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("promotions")
}

// ============ CONTRACTS ============

model Contract {
  id                String    @id @default(cuid())
  companyId         String
  employeeId        String
  employeeName      String?
  type              String
  startDate         DateTime
  endDate           DateTime?
  probationEndDate  DateTime?
  basicSalary       Float     @default(0)
  terms             String?   @db.Text
  status            String    @default("Active")
  terminatedAt      DateTime?
  terminationReason String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("contracts")
}

// ============ ASSETS ============

model Asset {
  id            String            @id @default(cuid())
  companyId     String
  name          String
  category      String
  serialNumber  String?           @unique
  model         String?
  purchaseDate  DateTime?
  purchasePrice Float             @default(0)
  status        String            @default("Available")
  condition     String            @default("Good")
  location      String?
  assignedTo    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  assignments   AssetAssignment[]

  @@index([companyId])
  @@index([category])
  @@index([status])
  @@map("assets")
}

model AssetAssignment {
  id           String    @id @default(cuid())
  assetId      String
  assetName    String?
  employeeId   String
  employeeName String?
  assignedDate DateTime  @default(now())
  returnDate   DateTime?
  status       String    @default("Active")
  condition    String?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  asset        Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([employeeId])
  @@map("asset_assignments")
}

// ============ BENEFITS ============

model Benefit {
  id                   String              @id @default(cuid())
  companyId            String
  name                 String
  type                 String
  description          String?             @db.Text
  employeeContribution Float               @default(0)
  employerContribution Float               @default(0)
  eligibility          String?
  status               String              @default("Active")
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  enrollments          BenefitEnrollment[]

  @@index([companyId])
  @@index([type])
  @@map("benefits")
}

model BenefitEnrollment {
  id            String   @id @default(cuid())
  benefitId     String
  benefitName   String?
  employeeId    String
  employeeName  String?
  effectiveDate DateTime @default(now())
  status        String   @default("Active")
  enrolledAt    DateTime @default(now())
  benefit       Benefit  @relation(fields: [benefitId], references: [id], onDelete: Cascade)

  @@unique([benefitId, employeeId])
  @@index([benefitId])
  @@index([employeeId])
  @@map("benefit_enrollments")
}

// ============ DISCIPLINARY ============

model DisciplinaryCase {
  id           String               @id @default(cuid())
  companyId    String
  employeeId   String
  employeeName String?
  incident     String
  description  String               @db.Text
  date         DateTime
  reportedBy   String?
  severity     String               @default("Moderate")
  status       String               @default("Open")
  notes        String?              @db.Text
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  actions      DisciplinaryAction[]

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@map("disciplinary_cases")
}

model DisciplinaryAction {
  id            String           @id @default(cuid())
  caseId        String
  type          String
  description   String           @db.Text
  effectiveDate DateTime
  issuedBy      String?
  status        String           @default("Pending")
  createdAt     DateTime         @default(now())
  case          DisciplinaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("disciplinary_actions")
}

// ============ COMPLIANCE ============

model ComplianceRequirement {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?  @db.Text
  authority   String
  frequency   String   @default("Monthly")
  dueDate     DateTime
  status      String   @default("Pending")
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@map("compliance_requirements")
}

model StatutoryFiling {
  id        String    @id @default(cuid())
  companyId String
  type      String
  period    String
  amount    Float     @default(0)
  dueDate   DateTime
  authority String
  status    String    @default("Pending")
  reference String?
  filedDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([companyId])
  @@index([type])
  @@index([status])
  @@map("statutory_filings")
}

// ============ ANNOUNCEMENTS ============

model Announcement {
  id          String    @id @default(cuid())
  companyId   String
  title       String
  content     String    @db.Text
  type        String    @default("General")
  priority    String    @default("Normal")
  audience    String    @default("All")
  publishedAt DateTime?
  expiresAt   DateTime?
  authorId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([type])
  @@index([priority])
  @@map("announcements")
}

// ============ NOTIFICATIONS ============

model Notification {
  id        String    @id @default(cuid())
  userId    String
  companyId String
  title     String
  message   String    @db.Text
  type      String    @default("Info")
  link      String?
  category  String?
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId])
  @@index([companyId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============ TASKS ============

model Task {
  id           String    @id @default(cuid())
  companyId    String
  title        String
  description  String?   @db.Text
  priority     String    @default("Normal")
  dueDate      DateTime?
  status       String    @default("Pending")
  assigneeId   String?
  assigneeName String?
  category     String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  updatedAt    DateTime  @updatedAt

  @@index([companyId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
  @@map("tasks")
}

// ============ DOCUMENTS ============

model Document {
  id          String    @id @default(cuid())
  companyId   String
  employeeId  String?
  name        String
  type        String    @default("File")
  category    String?
  url         String    @db.Text
  size        Int       @default(0)
  uploadedBy  String?
  description String?   @db.Text
  sharedWith  String?   @db.Text
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([employeeId])
  @@index([category])
  @@index([type])
  @@map("documents")
}

// ============ ANALYTICS ============

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  companyId String
  type      String
  data      String   @db.LongText
  period    String
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([type])
  @@index([period])
  @@map("analytics_snapshots")
}

// ============ SALARY INTELLIGENCE ============

model SalaryBenchmark {
  id             String   @id @default(cuid())
  companyId      String
  jobTitle       String
  department     String
  marketMin      Float
  marketMedian   Float
  marketMax      Float
  companyAverage Float    @default(0)
  percentile     Float    @default(50)
  recommendation String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([companyId, jobTitle, department])
  @@index([companyId])
  @@map("salary_benchmarks")
}

model SalaryStructure {
  id          String   @id @default(cuid())
  companyId   String
  grade       String
  level       String
  minSalary   Float
  midSalary   Float
  maxSalary   Float
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, grade, level])
  @@index([companyId])
  @@map("salary_structures")
}

// ============ EXACTAI ============

model AIChat {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  message   String   @db.Text
  response  String   @db.Text
  context   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@map("ai_chats")
}

model AIInsight {
  id          String   @id @default(cuid())
  companyId   String
  type        String
  title       String
  description String   @db.Text
  severity    String   @default("Info")
  category    String
  data        String?  @db.LongText
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([type])
  @@index([category])
  @@map("ai_insights")
}

// ============ HR QUERY ============

model FAQ {
  id          String   @id @default(cuid())
  companyId   String
  question    String   @db.Text
  answer      String   @db.Text
  category    String?
  views       Int      @default(0)
  helpfulness Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([category])
  @@map("faqs")
}

model HRTicket {
  id          String        @id @default(cuid())
  companyId   String
  userId      String
  userName    String?
  subject     String
  description String        @db.Text
  category    String?
  priority    String        @default("Normal")
  status      String        @default("Open")
  createdAt   DateTime      @default(now())
  closedAt    DateTime?
  updatedAt   DateTime      @updatedAt
  replies     TicketReply[]

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@map("hr_tickets")
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  userName  String?
  message   String   @db.Text
  createdAt DateTime @default(now())
  ticket    HRTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_replies")
}

// ============ INTEGRATIONS ============

model Integration {
  id         String    @id @default(cuid())
  companyId  String
  name       String
  type       String
  provider   String
  config     String?   @db.Text
  status     String    @default("ACTIVE")
  enabled    Boolean   @default(true)
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([companyId])
  @@index([type])
  @@map("integrations")
}

model Webhook {
  id        String   @id @default(cuid())
  companyId String
  url       String
  events    String   @db.Text
  secret    String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("webhooks")
}
