{
  "name": "ehrm-new-backend",
  "version": "1.0.0",
  "description": "ExactEHRM Microservices Backend - gRPC + Prisma + MySQL",
  "private": true,
  "scripts": {
    "build": "nest build",
    "build:all": "nest build api-gateway && nest build iam-service && nest build company-service && nest build employee-service && nest build attendance-service && nest build leave-service && nest build payroll-service && nest build performance-service && nest build training-service && nest build onboarding-service && nest build offboarding-service && nest build movement-service && nest build contracts-service && nest build assets-service && nest build benefits-service && nest build disciplinary-service && nest build compliance-service && nest build announcements-service && nest build analytics-service && nest build salary-intelligence-service && nest build exactai-service && nest build notifications-service && nest build tasks-service && nest build hr-query-service && nest build documents-service && nest build integrations-service",
    "start:gateway": "nest start api-gateway --watch",
    "start:iam": "nest start iam-service --watch",
    "start:company": "nest start company-service --watch",
    "start:employee": "nest start employee-service --watch",
    "start:attendance": "nest start attendance-service --watch",
    "start:leave": "nest start leave-service --watch",
    "start:payroll": "nest start payroll-service --watch",
    "start:performance": "nest start performance-service --watch",
    "start:training": "nest start training-service --watch",
    "start:onboarding": "nest start onboarding-service --watch",
    "start:offboarding": "nest start offboarding-service --watch",
    "start:movement": "nest start movement-service --watch",
    "start:contracts": "nest start contracts-service --watch",
    "start:assets": "nest start assets-service --watch",
    "start:benefits": "nest start benefits-service --watch",
    "start:disciplinary": "nest start disciplinary-service --watch",
    "start:compliance": "nest start compliance-service --watch",
    "start:announcements": "nest start announcements-service --watch",
    "start:analytics": "nest start analytics-service --watch",
    "start:salary-intelligence": "nest start salary-intelligence-service --watch",
    "start:exactai": "nest start exactai-service --watch",
    "start:notifications": "nest start notifications-service --watch",
    "start:tasks": "nest start tasks-service --watch",
    "start:hr-query": "nest start hr-query-service --watch",
    "start:documents": "nest start documents-service --watch",
    "start:integrations": "nest start integrations-service --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "ts-node prisma/seed.ts",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.10",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/config": "^3.2.3",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
