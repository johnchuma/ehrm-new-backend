# Copy this file to .env and fill in your values

# Database — MySQL
DATABASE_URL="mysql://root:password@localhost:3306/ehrm_new"

# JWT — change to a long random string in production
JWT_SECRET="change-me-to-a-very-long-random-string-at-least-64-chars"

# Super admin seed credentials
HRM_SUPER_ADMIN_EMAIL="admin@exactehrm.com"
HRM_SUPER_ADMIN_PASSWORD="Admin@2026!"

# Default password assigned to company admin accounts created by super admin
DEFAULT_COMPANY_ADMIN_PASSWORD="ChangeMe@2026!"

# Server
GATEWAY_PORT=3000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:5173"

# AI (optional)
OPENAI_API_KEY=""
GEMINI_API_KEY=""
